<?php
error_reporting(E_ALL);
ini_set('display_errors', 1);
session_start();
require_once "database.php";

if (!isset($_SESSION['admin_id'])) {
    header("Location: adminlogin.php");
    exit();
}

/* =========================
   TOTAL EVENTS
   ========================= */
$events = $conn->query("SELECT COUNT(*) AS total FROM events")->fetch_assoc();

/* =========================
   TOTAL PARTICIPANTS
   ========================= */
$participants = $conn->query("SELECT COUNT(*) AS total FROM users WHERE role='member'")->fetch_assoc();

/* =========================
   TOTAL PAYMENTS
   ========================= */
$payments = $conn->query("SELECT COALESCE(SUM(amount_paid),0) AS total FROM payments")->fetch_assoc();

/* =========================
   TOTAL ATTENDANCE
   ========================= */
$attendance = $conn->query("SELECT COUNT(*) AS total FROM attendance")->fetch_assoc();

/* =========================
   UPCOMING EVENTS
   ========================= */
$event_list = $conn->query("
    SELECT 
        id,
        event_name,
        event_date,
        location,
        CASE
            WHEN event_date > NOW() THEN 'Upcoming'
            WHEN DATE(event_date) = CURDATE() THEN 'Ongoing'
            ELSE 'Completed'
        END AS status
    FROM events
    ORDER BY event_date ASC
    LIMIT 5
");

/* =========================
   PAYMENT OVERVIEW
   ========================= */
$payment_overview = $conn->query("
    SELECT 
        SUM(e.fee) AS expected,
        COALESCE(SUM(p.amount_paid),0) AS collected,
        (SUM(e.fee) - COALESCE(SUM(p.amount_paid),0)) AS remaining
    FROM events e
    LEFT JOIN payments p ON p.event_id = e.id
")->fetch_assoc();
?>

