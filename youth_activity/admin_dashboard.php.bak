    </div>
</div>

<!-- CARDS (NOW DYNAMIC) -->
<div class="cards">

    <div class="card">
        <h3>Total Events</h3>
        <p><?= $events['total'] ?></p>
    </div>

    <div class="card">
        <h3>Total Participants</h3>
        <p><?= $participants['total'] ?></p>
    </div>

    <div class="card">
        <h3>Total Payments</h3>
        <p>₱<?= number_format($payments['total'], 2) ?></p>
    </div>

    <div class="card">
        <h3>Total Attendance</h3>
        <p><?= $attendance['total'] ?></p>
    </div>

</div>

<!-- EVENTS (LIVE DATA) -->
<div class="section">
<h2>Upcoming Events</h2>

<table>
<tr>
<th>Event</th>
<th>Date</th>
<th>Location</th>
<th>Status</th>
<th>Action</th>
</tr>

<?php while($e = $event_list->fetch_assoc()): ?>
<tr>
<td><?= htmlspecialchars($e['event_name']) ?></td>
<td><?= $e['event_date'] ?></td>
<td><?= htmlspecialchars($e['location']) ?></td>
<td>
    <span class="status-pill"><?= $e['status'] ?></span>
</td>
<td>
    <button onclick="location.href='edit_event.php?id=<?= $e['id'] ?>'">
        Edit
    </button>
</td>
</tr>
<?php endwhile; ?>

</table>
</div>

<!-- BOTTOM STATS -->
<div class="grid-2">

<div class="section">
<h2>Attendance Summary</h2>

<?php
$att = $conn->query("
    SELECT 
        e.event_name,
        COUNT(a.id) AS present
    FROM events e
    LEFT JOIN attendance a ON a.event_id = e.id
    GROUP BY e.id
    LIMIT 1
")->fetch_assoc();
?>

<p>
<?= $att['event_name'] ?? 'No Event' ?>:
<strong><?= $att['present'] ?? 0 ?></strong>
</p>

</div>

<div class="section">
<h2>Payment Overview</h2>

<p>Total Expected:
<strong>₱<?= number_format($payment_overview['expected'], 2) ?></strong></p>

<p>Total Collected:
<strong style="color:#2980b9;">
₱<?= number_format($payment_overview['collected'], 2) ?>
</strong></p>

<p>Remaining:
<strong style="color:#e05a2b;">
₱<?= number_format($payment_overview['remaining'], 2) ?>
</strong></p>

</div>

</div>

</div>
</div>

</body>
</html>